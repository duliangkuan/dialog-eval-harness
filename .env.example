# Real model provider. Any OpenAI-compatible /v1/chat/completions endpoint works.
MODEL_PROVIDER=openai-compatible
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=replace_me
OPENAI_MODEL=gpt-4.1-mini

# Optional production API auth. If set, POST APIs require x-api-key.
APP_API_KEY=replace_with_random_secret

# Optional: call the real outbound Agent instead of the built-in model adapter.
# The endpoint must accept { policy, caseInput, transcript, repairHints }
# and return { text }.
TEST_AGENT_ENDPOINT=
TEST_AGENT_API_KEY=

# Local smoke only. Do not use this in production.
# MODEL_PROVIDER=mock
